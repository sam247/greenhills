# Copy to .env.local for local development. Set these in Vercel project settings for production.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Production site URL (auth email redirects, password reset). On Vercel you can omit if using VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
